# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and read by docker-compose (`POSTGRES_*` vars below).
# For Spring Boot to pick these up, also expose them via your IDE Run Configuration
# OR run `./gradlew bootRun` from a shell that has them exported.

# --- PostgreSQL (used by docker-compose AND Spring Boot) ---
POSTGRES_DB=bookmark
POSTGRES_USER=bookmark
POSTGRES_PASSWORD=change_me_locally

# --- Spring Boot DB (must match the POSTGRES_* values above for local dev) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookmark
DB_USERNAME=bookmark
DB_PASSWORD=change_me_locally

# --- Google OAuth ---
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
# IMPORTANT: copy values directly from Google Console. Do not OCR / transcribe via other tools —
# a single wrong character causes `invalid_client` errors that look identical to a wrong key.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Frontend ---
FRONTEND_URL=http://localhost:5173
