{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/u/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Twitterbot|facebookexternalhit|kakaotalk-scrap|Discordbot|Slackbot|LinkedInBot|Applebot|Googlebot|Bingbot|TelegramBot|WhatsApp|SkypeUriPreview|Iframely).*"
        }
      ],
      "destination": "https://bookmark-library-production.up.railway.app/u/:path*"
    },
    {
      "source": "/u/:path*",
      "destination": "/index.html"
    },
    { "source": "/api/:path*", "destination": "https://bookmark-library-production.up.railway.app/api/:path*" },
    { "source": "/og/:path*", "destination": "https://bookmark-library-production.up.railway.app/og/:path*" },
    { "source": "/oauth2/:path*", "destination": "https://bookmark-library-production.up.railway.app/oauth2/:path*" },
    { "source": "/login/oauth2/:path*", "destination": "https://bookmark-library-production.up.railway.app/login/oauth2/:path*" },
    { "source": "/logout", "destination": "https://bookmark-library-production.up.railway.app/logout" }
  ]
}
